{
  "name": "tailfeather",
  "version": "1.0.0",
  "description": "Utilities for Noterook",
  "scripts": {
    "test": "web-ext lint",
    "posttest": "eslint ./",
    "build": "web-ext build",
    "start:dev": "web-ext run --firefox=deved -t=firefox-desktop",
    "start:adb": "web-ext run -t=firefox-android --adb-device=001691569000791 --firefox-apk=org.mozilla.fenix --adb-remove-old-artifacts"
  },
  "author": "Cassiopeia Lunarii",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "eslint": "^8.57.0",
    "web-ext": "^10.0.0"
  },
  "dependencies": {
    "ace-builds": "^1.43.6",
    "culori": "^4.0.2",
    "dompurify": "^3.0.9",
    "luxon": "^3.7.2",
    "marked": "^14.1.2",
    "noble-ed25519": "^1.2.6",
    "prismjs": "^1.29.0"
  },
  "webExt": {
    "sourceDir": "src/",
    "build": {
      "overwriteDest": true
    },
    "run": {
      "firefox": "deved"
    }
  }
}
